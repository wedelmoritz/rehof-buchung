# ---- Von install.sh automatisch befüllt (SECRET_KEY, DB-Passwort) ----
SECRET_KEY=
POSTGRES_PASSWORD=

# ---- Anzupassen ----
# Domain(s), unter denen die App erreichbar ist (kommagetrennt).
# 10.42.42.20 ist die Container-IP für interne Health-Checks – weglassen,
# falls keine genutzt werden.
ALLOWED_HOSTS=quartiere.example.de,10.42.42.20
# Muss als https-Origin angegeben werden (für CSRF hinter Caddy):
CSRF_TRUSTED_ORIGINS=https://quartiere.example.de

# ---- Datenbank ----
POSTGRES_DB=rehof
POSTGRES_USER=rehof

# ---- Betrieb ----
# Caddy läuft als Container im selben Docker-Netz und erreicht web:8000 direkt;
# es wird bewusst KEIN Host-Port veröffentlicht.
GUNICORN_WORKERS=3
# Zeitzone (für Logs/Monatswechsel des Schedulers) und Scheduler-Intervall.
TZ=Europe/Berlin
CRON_INTERVAL_SECONDS=900   # alle 15 Min fällige Losungen prüfen/ausführen
# Test-/Demo-Daten (für Docker, da kein Python auf dem Host nötig).
# Genau EINE Option auf 1 setzen, Stack neu starten, DANACH wieder auf 0!
# (sonst läuft die Aktion bei jedem Neustart erneut)
SEED_DEMO=0            # 1 = Test-/Demo-Daten anlegen (Nutzer, Tandems, Hofladen)
DEMO_RESET=0          # 1 = ALLE Daten löschen UND Demo neu anlegen (Vorsicht!)
DEMO_WIPE=0           # 1 = NUR ALLE Daten löschen (Vorsicht!)
SECURE_HSTS_SECONDS=0   # z.B. 31536000 aktivieren, wenn alles per HTTPS läuft

# ---- Sicherheit: Backend-2FA (ADR 0061, siehe docs/2FA-BACKEND.md) ----
# Zwei-Faktor (TOTP) fürs Backend /admin/. Default in Produktion: AN.
#   1 = an (vorher EINMAL ein Gerät einrichten, sonst sperrt man sich aus:
#       docker compose exec web python manage.py admin_otp_setup --user <name>)
#   0 = aus (z.B. zum Wiedereinstieg nach einem Lockout)
# NICHT leer lassen – leer würde 2FA ausschalten.
ADMIN_OTP_REQUIRED=1

# ---- E-Mail (leer lassen = Konsole/Log; für echten Versand ausfüllen) ----
# Öffentliche Basis-URL für Links in E-Mails:
PUBLIC_BASE_URL=https://quartiere.example.de
DEFAULT_FROM_EMAIL=Re:Hof <noreply@quartiere.example.de>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0

# ---- Optional: Redis (Cache/Sessions/Brute-Force-Zähler) ----
# Leer lassen = aus (DB-Sessions). Zum Aktivieren beides tun:
#   1) hier setzen:           REDIS_URL=redis://redis:6379/0
#   2) Dienst mitstarten:     docker compose --profile cache up -d
REDIS_URL=

# ---- Optional: Observability (ADR 0046) ----
# Sentry-Fehler-Tracking: leer = aus. DSN aus dem Sentry-Projekt eintragen.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0     # >0 = Performance-Sampling (z.B. 0.1)
LOG_LEVEL=INFO                  # DEBUG/INFO/WARNING – Log-Ausführlichkeit (stdout)
# Health-Check für externes Uptime-Monitoring: GET https://<domain>/healthz/ → 200

# ---- Optional: Web-Push (mobil, ADR 0044) ----
# Leer = Push aus. Schlüsselpaar erzeugen mit:  python manage.py vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=
