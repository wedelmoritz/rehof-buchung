# ---- Von install.sh automatisch befüllt (SECRET_KEY, DB-Passwort) ----
SECRET_KEY=
POSTGRES_PASSWORD=

# ---- Anzupassen ----
# Domain(s), unter denen die App erreichbar ist (kommagetrennt):
ALLOWED_HOSTS=quartiere.example.org
# Muss als https-Origin angegeben werden (für CSRF hinter Caddy):
CSRF_TRUSTED_ORIGINS=https://quartiere.example.org

# ---- Datenbank ----
POSTGRES_DB=rehof
POSTGRES_USER=rehof

# ---- Betrieb ----
WEB_PORT=8000           # localhost-Port, auf den Caddy proxyt
GUNICORN_WORKERS=3
SEED_DEMO=0             # 1 = beim ersten Start Demo-Daten anlegen
SECURE_HSTS_SECONDS=0   # z.B. 31536000 aktivieren, wenn alles per HTTPS läuft
